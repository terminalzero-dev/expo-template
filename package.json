{
  "name": "@terminalzero/expo-template",
  "version": "1.0.0",
  "description": "Opinionated, batteries-included Expo (React Native) starter template: Expo Router with typed routes, native tabs, light/dark theming, React Compiler, and a pure oxc (oxlint + oxfmt) toolchain wired to lefthook git hooks.",
  "keywords": [
    "expo",
    "expo-router",
    "react-native",
    "react-native-web",
    "template",
    "starter",
    "typescript",
    "bun",
    "oxc",
    "oxlint",
    "oxfmt",
    "lefthook",
    "ios",
    "android",
    "web"
  ],
  "homepage": "https://github.com/terminalzero-dev/expo-template#readme",
  "bugs": {
    "url": "https://github.com/terminalzero-dev/expo-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terminalzero-dev/expo-template.git"
  },
  "license": "MIT",
  "author": "Terminal Zero <tevinx@terminalzero.dev> (https://terminalzero.dev)",
  "main": "expo-router/entry",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22.18.0",
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@expo/ui": "~56.0.17",
    "expo": "~56.0.11",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.10",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~3.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@terminalzero/oxc-config-expo": "^0.1.0",
    "@types/react": "~19.2.17",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "taze": "^19.14.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "tunnel": "expo start --tunnel",
    "lint": "NODE_OPTIONS=--disable-warning=MODULE_TYPELESS_PACKAGE_JSON oxlint",
    "lint:fix": "NODE_OPTIONS=--disable-warning=MODULE_TYPELESS_PACKAGE_JSON oxlint --fix",
    "format": "NODE_OPTIONS=--disable-warning=MODULE_TYPELESS_PACKAGE_JSON oxfmt",
    "format:check": "NODE_OPTIONS=--disable-warning=MODULE_TYPELESS_PACKAGE_JSON oxfmt --check",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "reset-project": "node ./scripts/reset-project.js",
    "up:deps": "taze -I major",
    "prepare": "lefthook install"
  }
}
